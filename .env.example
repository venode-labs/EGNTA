# Egenta runtime config. Copy to .env (gitignored) and fill what you use.

# Deep brain (Phase 4). Without this the daemon still triages locally; the deep
# brain stays dormant and every escalation degrades to a 'pending' finding.
ANTHROPIC_API_KEY=
# Optional deep-brain tuning.
EGENTA_DEEP_MODEL=claude-sonnet-4-6
EGENTA_SALIENCE_THRESHOLD=0.5
EGENTA_RECURRENCE_MIN=3

# Local triage brain (Phase 2), Ollama on this box.
EGENTA_LOCAL_MODEL=qwen2.5:3b

# Training arm (Phase 7), deferred.
HF_TOKEN=
WANDB_API_KEY=
TRACKIO_API_KEY=
